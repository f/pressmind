{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"landingPage": "/wp-admin/post.php?post=1001&action=edit",
	"preferredVersions": {
		"php": "8.2",
		"wp": "latest"
	},
	"features": {
		"networking": true
	},
	"login": true,
	"steps": [
		{
			"step": "login",
			"username": "admin",
			"password": "password"
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "git:directory",
				"url": "https://github.com/f/pressmind",
				"path": "/",
				"ref": "main"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "runPHP",
			"code": "<?php require_once '/wordpress/wp-load.php'; $content_file = WP_PLUGIN_DIR . '/pressmind/examples/pressmind-demo-post.html'; $content = file_exists( $content_file ) ? file_get_contents( $content_file ) : '<!-- wp:paragraph --><p>Pressmind example content could not be loaded.</p><!-- /wp:paragraph -->'; wp_insert_post( array( 'import_id' => 1001, 'post_title' => 'Pressmind Demo: AI-Ready Blocks', 'post_name' => 'pressmind-demo-ai-ready-blocks', 'post_content' => $content, 'post_status' => 'publish', 'post_author' => 1 ) );"
		}
	]
}
